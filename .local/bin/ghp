#!/usr/bin/env zsh
#
# ghp - pass-backed wrapper for the GitHub CLI.
#
# Package:
#   forge-cli-auth
#
# Purpose:
#   Run `gh` with a GitHub token read from password-store (`pass`),
#   without relying on the normal GitHub CLI credential store.
#
# In this package, a "forge" means a source-code collaboration platform
# such as GitHub, GitLab, Gitea, Forgejo, SourceHut, or Bitbucket.
#
# Secret source:
#   pass entry: tokens/github/gh-oauth
#
# Notes:
#   - Only the first line of the pass entry is used as the token.
#     This allows optional metadata/comments below the token.
#   - `GH_TOKEN` is scoped only to the `gh` process launched here.
#   - xtrace is disabled to reduce the risk of leaking token material
#     through shell debugging output.

emulate -R zsh
unsetopt xtrace
umask 077

PASS_ENTRY="tokens/github/gh-oauth"

die() {
  print -u2 -- "ghp: $*"
  exit 1
}

require_cmd() {
  command -v "$1" >/dev/null 2>&1 || die "missing dependency: $1"
}

require_cmd pass
require_cmd gh

token="$(pass show "$PASS_ENTRY")" || die "failed to read token from pass: $PASS_ENTRY"

# Use only the first line, matching the common `pass` convention where
# line 1 is the secret and later lines may contain metadata.
token="${token%%$'\n'*}"

[[ -n "$token" ]] || die "pass entry is empty: $PASS_ENTRY"

GH_TOKEN="$token" command gh "$@"
