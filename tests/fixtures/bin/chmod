#!/bin/sh
# SPDX-License-Identifier: Apache-2.0

set -u

: "${REAL_CHMOD:?}"
: "${FAKE_CHMOD_COUNT_FILE:?}"

call_count=0

if [ -f "$FAKE_CHMOD_COUNT_FILE" ]; then
    IFS= read -r call_count <"$FAKE_CHMOD_COUNT_FILE" ||
        call_count=0
fi

call_count=$((call_count + 1))
printf '%s\n' "$call_count" >"$FAKE_CHMOD_COUNT_FILE"

if [ "${FAKE_CHMOD_FAIL_ON_CALL:-0}" -eq "$call_count" ]; then
    exit "${FAKE_CHMOD_STATUS:-1}"
fi

exec "$REAL_CHMOD" "$@"
